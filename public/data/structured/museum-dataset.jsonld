      "@type": "Photograph",
      "@id": "urn:milreu:memory:MM202601",
      "identifier": "MM202601",
      "name": "Um aspecto do cortejo da Festa da Pinha, em Estoi",
      "abstract": "Registo do cortejo da Festa da Pinha em Estoi, em 1909, em frente à Casa Rural de Milreu.",
      "dateCreated": "1909-05-02",
      "temporalCoverage": "1909-05-02",
      "about": [
        "Festa da Pinha",
        "Estoi",
        "Casa Rural",
        "Milreu",
        "Torre do Tombo",
        "José Viegas Samorrinha",
        "1909"
      ],
      "image": {
        "@type": "ImageObject",
        "@id": "urn:milreu:image:MM202601",
        "contentUrl": "public/media/museum/generated/MM202601/detail.webp",
        "thumbnailUrl": "public/media/museum/generated/MM202601/thumbnail.webp",
        "caption": "Fotografia que documenta um aspeto do cortejo da Festa da Pinha, em Estoi, datada de 2 de maio de 1909. A imagem mostra o cortejo a passar em frente à Casa Rural de Milreu, com elementos festivos, cavalo ornamentado e participantes com trajes especiais. A fotografia pertence ao acervo do Arquivo Nacional da Torre do Tombo, no fundo Foto Artística Samorrinha, com autoria de José Viegas Samorrinha. A leitura comunitária indica que o cortejo passa em frente às ruínas, sendo possível observar a paisagem característica do Monte Malhão e a Casa Rural.",
        "creditText": "Arquivo Nacional da Torre do Tombo — Foto Artística Samorrinha. Autor: José Viegas Samorrinha. Código de referência: PT/TT/SAM/A/001/000016.",
        "copyrightNotice": "Consultar os direitos e créditos do registo."
      },
      "url": "museu/memorias/MM202601/"
    },
