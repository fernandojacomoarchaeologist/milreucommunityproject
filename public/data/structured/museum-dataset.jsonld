    {
      "@type": "Photograph",
      "@id": "urn:milreu:memory:MM202613",
      "identifier": "MM202613",
      "name": "Theodor Hauschild e equipa de escavadores em Milreu",
      "abstract": "Fotografia de grupo associada às campanhas arqueológicas de Milreu com o Instituto Arqueológico Alemão.",
      "dateCreated": "1981",
      "temporalCoverage": "ca. 1981, segundo hipótese de Cristina Farias",
      "about": [
        "Milreu",
        "escavações",
        "Theodor Hauschild",
        "Instituto Arqueológico Alemão",
        "Casa Rural",
        "Pedro Fialho de Sousa",
        "Cristina Farias"
      ],
      "image": {
        "@type": "ImageObject",
        "@id": "urn:milreu:image:MM202613",
        "contentUrl": "public/media/museum/generated/MM202613/detail.webp",
        "thumbnailUrl": "public/media/museum/generated/MM202613/thumbnail.webp",
        "caption": "Fotografia de Theodor Hauschild e sua equipa de escavadores em Milreu, associada às campanhas arqueológicas realizadas por volta dos anos 1970 e início dos anos 1980. A fotografia pertence à coleção de Maria de Lurdes Mendes Martins e foi providenciada por Celeste Pimenta e Branca Pimenta, filhas de Dona Noémia Cruz, conhecida como “papo seco”. A imagem mostra 19 indivíduos no que aparenta ser o lado sudoeste externo da Casa Rural, próximo das colunas. Cristina Farias identificou desenhadores do Instituto Arqueológico Alemão, o arquiteto Pedro Fialho de Sousa e trabalhadores contratados para a escavação.",
        "creditText": "Coleção de Maria de Lurdes Mendes Martins; fotografia providenciada por Celeste Pimenta e Branca Pimenta.",
        "copyrightNotice": "Consultar os direitos e créditos do registo."
      },
      "url": "museu/memorias/MM202613/"
    },
    {
      "@type": "Photograph",
      "@id": "urn:milreu:memory:MM202614",
      "identifier": "MM202614",
      "name": "Equipa de escavadores em Milreu sobre os mosaicos",
      "abstract": "Fotografia de grupo das campanhas arqueológicas de Milreu, com 31 indivíduos sobre os mosaicos.",
      "dateCreated": "1981",
      "temporalCoverage": "Provavelmente 1981, segundo testemunho de Cristina Farias",
      "about": [
        "Milreu",
        "escavações",
        "mosaicos",
        "Instituto Arqueológico Alemão",
        "Cristina Farias",
        "Pedro Fialho de Sousa",
        "Casa Rural"
      ],
      "image": {
        "@type": "ImageObject",
        "@id": "urn:milreu:image:MM202614",
        "contentUrl": "public/media/museum/generated/MM202614/detail.webp",
        "thumbnailUrl": "public/media/museum/generated/MM202614/thumbnail.webp",
        "caption": "Fotografia da equipa de escavadores em Milreu durante campanhas associadas ao Instituto Arqueológico Alemão. A imagem mostra 31 indivíduos no que aparenta ser a zona dos mosaicos próxima ao ponto central, no lado oeste da Casa Rural. A fotografia foi providenciada por Celeste Pimenta e Branca Pimenta. No verso há marcas de manuseio, amarelamento, dobras, manchas e o número “8” escrito a lápis. Cristina Farias aparece na fotografia e indicou detalhes importantes sobre a presença de desenhadores do Instituto Arqueológico Alemão, do arquiteto Pedro Fialho de Sousa e de trabalhadores contratados.",
        "creditText": "Fotografia providenciada por Celeste Pimenta e Branca Pimenta; associada à coleção de Maria de Lurdes Mendes Martins.",
        "copyrightNotice": "Consultar os direitos e créditos do registo."
      },
      "url": "museu/memorias/MM202614/"
    },
